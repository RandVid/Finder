# Copy to .env and adjust if needed.
DATABASE_URL=postgresql://finder:finder@localhost:5432/finder
SECRET_KEY=change-me-to-a-long-random-string
BASE_URL=

# Cloudinary (optional — only needed for cloud deployments).
# If not set, photos are saved to backend/static/photos/ (local dev).
# Get these from https://cloudinary.com → Dashboard → API Keys.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
