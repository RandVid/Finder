// Finder — sync with db/schema.sql (Alembic 001 + 002)

Enum swipe_direction {
  smash
  pass
}

Enum profile_gender {
  woman
  man
  nonbinary
}

Enum looking_for {
  women
  men
  everyone
}

Enum hair_color {
  black
  brown
  blonde
  red
  gray
  other
}

Table users {
  id int [pk, increment]
  email varchar(255) [not null, unique]
  password_hash varchar(255) [not null]
  created_at timestamptz [not null, default: `now()`]
}

Table profiles {
  user_id int [pk, ref: > users.id]
  display_name varchar(120) [not null]
  bio text
  birth_date date
  city varchar(120)
  gender profile_gender
  looking_for looking_for
  hair_color hair_color
  height_cm int
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (hair_color)
    (updated_at)
    (city)
  }
}

Table dating_preferences {
  user_id int [pk, ref: > users.id]
  partner_age_min int
  partner_age_max int
  prefer_same_city boolean [not null, default: false]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Scalar filters only (1NF). Multi-valued partner genders/hair colors live in child tables below.'
}

Table dating_preference_genders {
  user_id int [not null, ref: > dating_preferences.user_id]
  gender profile_gender [not null]

  indexes {
    (user_id, gender) [pk]
    (gender)
  }
}

Table dating_preference_hair_colors {
  user_id int [not null, ref: > dating_preferences.user_id]
  hair_color hair_color [not null]

  indexes {
    (user_id, hair_color) [pk]
    (hair_color)
  }
}

Table swipes {
  id int [pk, increment]
  swiper_user_id int [not null, ref: > users.id]
  target_user_id int [not null, ref: > users.id]
  direction swipe_direction [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (swiper_user_id)
    (target_user_id)
    (target_user_id, created_at)
  }
}

Table matches {
  id int [pk, increment]
  user_low_id int [not null, ref: > users.id, note: 'always smaller users.id']
  user_high_id int [not null, ref: > users.id, note: 'always larger users.id']
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_low_id)
    (user_high_id)
  }
}

Table messages {
  id int [pk, increment]
  match_id int [not null, ref: > matches.id]
  sender_user_id int [not null, ref: > users.id]
  body text [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (match_id)
    (sender_user_id)
    (match_id, created_at)
  }

  Note: 'Chat thread key: user taps a match in the list → app uses matches.id → SELECT messages WHERE match_id = …. Storing both user ids on each message would duplicate the match row and complicate history queries.'
}
